{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.imotinadezhda.bg" }],
      "destination": "https://imotinadezhda.bg/:path*",
      "permanent": true
    }
  ]
}
