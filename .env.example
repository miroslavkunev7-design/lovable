# ── Vercel (hosting) + Supabase (PostgreSQL) ───────────────────
# Свържи Supabase от Vercel Dashboard → Storage → Supabase → Connect
# След connect Vercel inject-ва POSTGRES_URL автоматично.

POSTGRES_URL=
DATABASE_URL=
POSTGRES_URL_NON_POOLING=

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://imoti-nadezhda.vercel.app
NEXT_PUBLIC_MEDIA_URL=https://imoti-nadezhda.vercel.app

# ── Admin (NextAuth) ───────────────────────────────────────────
ADMIN_EMAIL=imoti_nadejdi@abv.bg
ADMIN_PASSWORD=
NEXTAUTH_SECRET=

# ── Контакти ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Имоти Надежда
NEXT_PUBLIC_CONTACT_PHONE=+359899620262
NEXT_PUBLIC_CONTACT_EMAIL=agenciq_nadejdi@abv.bg

# ── Cloudinary (optional) ──────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

